# URL del snapshot JSON generado por el módulo /portfolio/export del backoffice
# En desarrollo: vacío (los datos se sirven desde public/snapshot.json)
# En producción: URL pública del snapshot o vacío si se embebe en el build
NUXT_PUBLIC_SNAPSHOT_URL=

# URL pública del sitio (canonical, og:url, sitemap)
NUXT_PUBLIC_SITE_URL=https://tu-dominio.vercel.app

# Destino del formulario de contacto (mailto). Vacío = formulario deshabilitado con aviso en UI.
NUXT_PUBLIC_CONTACT_EMAIL=

# Ruta o URL del CV para el botón del hero. Vacío = botón oculto. Ej.: /cv.pdf (archivo en public/)
NUXT_PUBLIC_CV_URL=
